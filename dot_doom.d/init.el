;;; init.el -*- lexical-binding: t; -*-

;; =============================================================================
;; 1. COMPLETION & SEARCH
;; =============================================================================

(doom! :completion
       (corfu +orderless)
       vertico

;; =============================================================================
;; 2. UI & LOOK-AND-FEEL
;; =============================================================================

       :ui
       (doom +icons)
       (doom-dashboard +icons)
       hl-todo
       indent-guides
       (modeline +icons)
       ophints
       (popup +defaults)
       solaire
       syntax
       vc-gutter +pretty
       workspaces
       zen

;; =============================================================================
;; 3. EDITOR & BEHAVIOR
;; =============================================================================

       :editor
       (evil +everywhere)
       file-templates
       fold
       (format +onsave)
       snippets
       word-wrap

;; =============================================================================
;; 4. EMACS CORE & OS
;; =============================================================================

       :emacs
       (dired +icons +dirvish)
       undo

       :os
       (:if (featurep :system 'macos) macos)

;; =============================================================================
;; 5. LANGUAGES & TOOLS
;; =============================================================================

       :lang
       markdown
       (org +roam +pomodoro)

;; =============================================================================
;; 6. DEFAULT CONFIGURATION
;; =============================================================================

       :config
       (default +bindings +smartparens))
